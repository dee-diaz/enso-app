{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",

    "strict": true,
    "noImplicitAny": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "outDir": "./.tsbuild"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}